# ===========================================
# Career Accelerator — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# cp .env.local.example .env.local
#
# NEVER commit .env.local to git (already in .gitignore)
# ===========================================

# --- Google OAuth (SP1-05) ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (dev): http://localhost:3000/api/auth/callback/google
# Authorized redirect URI (prod): https://<your-vercel-url>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- NextAuth.js ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Dev: http://localhost:3000 | Prod: https://<your-vercel-url>
NEXTAUTH_URL=http://localhost:3000

# --- Database (SP1-02, SP1-03) ---
# Supabase PostgreSQL connection strings
# Found in: Supabase Dashboard > Settings > Database > Connection string (URI)
#
# IMPORTANT: Supabase free tier direct connections are IPv6-only.
# If you are on an IPv4 network (most home/office networks), the direct
# connection will timeout silently. Use the **Session Pooler** string instead:
#   - Supabase Dashboard > Settings > Database > Connection string > Session Pooler
#   - Host looks like: aws-0-<region>.pooler.supabase.com (port 5432)
#
# If you are on an IPv6 network, you can use the direct connection:
#   - Host looks like: db.<ref>.supabase.co (port 5432)
#
# Set both DATABASE_URL and DIRECT_URL to the same connection string.
# DATABASE_URL is used by the app at runtime. DIRECT_URL is used by Prisma migrations.
DATABASE_URL=
DIRECT_URL=

# --- LLM (Sprint 2) ---
# Anthropic API key for Claude
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=